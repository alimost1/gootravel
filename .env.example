# ============================================================
# Required Environment Variables — Set these in Coolify
# ============================================================
# Copy this file, fill in the values, and paste into
# Coolify → Your App → Environment Variables

# --- Database ---
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=your_strong_password_here
DB_HOST=db
DB_TABLE_PREFIX=wp_

# --- WordPress URLs (use your real domain with https) ---
WP_HOME=https://yourdomain.com
WP_SITEURL=https://yourdomain.com

# --- WordPress Debug (set to false in production) ---
WP_DEBUG=false

# --- WordPress Secret Keys ---
# Generate fresh values at: https://api.wordpress.org/secret-key/1.1/salt/
AUTH_KEY=generate-a-unique-secret-here
SECURE_AUTH_KEY=generate-a-unique-secret-here
LOGGED_IN_KEY=generate-a-unique-secret-here
NONCE_KEY=generate-a-unique-secret-here
AUTH_SALT=generate-a-unique-secret-here
SECURE_AUTH_SALT=generate-a-unique-secret-here
LOGGED_IN_SALT=generate-a-unique-secret-here
NONCE_SALT=generate-a-unique-secret-here

# --- MySQL (for the db container) ---
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=your_strong_password_here
MYSQL_ROOT_PASSWORD=your_root_password_here
